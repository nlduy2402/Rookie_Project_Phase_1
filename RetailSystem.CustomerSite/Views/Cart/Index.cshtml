@using RetailSystem.Domain.Entities
@model Cart

<style>
        .table td, .table th {
        vertical-align: middle;
    }

    input[type="number"] {
        max-width: 70px;
    }
</style>
<div class="container my-5">
    <h3 class="mb-4">Shopping Cart</h3>

    @if (Model == null || !Model.Items.Any())
    {
        <div class="alert alert-info">
            Your cart is empty
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table align-middle">
                <thead class="table-light">
                    <tr>
                        <th>Product</th>
                        <th width="120">Price</th>
                        <th width="150">Quantity</th>
                        <th width="120">Total</th>
                        <th width="100"></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.Items)
                    {
                        <tr>
                            <!-- Product -->
                            <td>
                                <strong>@item.Product.Name</strong>
                            </td>

                            <!-- Price -->
                            <td>
                                @item.Product.Price.ToString("N0") đ
                            </td>

                            <!-- Quantity -->
                            <td>
                                <form asp-action="Update" method="post" class="d-flex">
                                    <input type="hidden" name="productId" value="@item.ProductId" />

                                    <input type="number"
                                           name="quantity"
                                           value="@item.Quantity"
                                           min="1"
                                           class="form-control me-2" />

                                    <button class="btn btn-outline-primary btn-sm">
                                        Update
                                    </button>
                                </form>
                            </td>

                            <!-- Total -->
                            <td>
                                @((item.Quantity * item.Product.Price).ToString("N0")) đ
                            </td>

                            <!-- Remove -->
                            <td>
                                <form asp-action="Remove" method="post">
                                    <input type="hidden" name="productId" value="@item.ProductId" />
                                    <button class="btn btn-outline-danger btn-sm">
                                        ✕
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <!-- TOTAL + ACTION -->
        <div class="card shadow-sm border-0 mt-4">
            <div class="card-body p-4">
                <div class="row align-items-center">
                    <!-- Phần bên trái: Nút xóa giỏ hàng -->
                    <div class="col-md-4 order-2 order-md-1 mt-3 mt-md-0">
                        <form asp-action="Clear" asp-controller="Cart" method="post"
                              onsubmit="return confirm('Are you sure to delete all item in your cart?')">
                            <button class="btn btn-link text-danger text-decoration-none p-0">
                                <i class="bi bi-trash3 me-1"></i> Clear Cart
                            </button>
                        </form>
                    </div>

                    <div class="col-md-8 order-1 order-md-2 text-md-end">
                        <div class="d-flex flex-column flex-md-row align-items-md-center justify-content-md-end gap-4">
                            <div class="mb-2 mb-md-0">
                                <span class="text-muted text-uppercase small fw-bold">Total:</span>
                                <h3 class="text-primary mb-0 fw-bold">
                                    @Model.Items.Sum(i => i.Quantity * i.Product!.Price).ToString("N0") <span class="fs-6">₫</span>
                                </h3>
                            </div>

                            <a asp-action="index" asp-controller="Order"
                               class="btn btn-primary btn-lg px-5 py-3 rounded-pill shadow-sm fw-bold">
                                Checkout Now <i class="bi bi-arrow-right ms-2"></i>
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }
</div>