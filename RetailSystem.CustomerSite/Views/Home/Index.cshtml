<script>
    const list = document.querySelector('.category-list');
    const next = document.querySelector('.next');
    const prev = document.querySelector('.prev');

    next.onclick = () => {
        list.scrollBy({ left: 200, behavior: 'smooth' });
    };

    prev.onclick = () => {
        list.scrollBy({ left: -200, behavior: 'smooth' });
    };
</script>




