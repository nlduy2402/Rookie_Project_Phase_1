    <style>
        .laptop-card {
            border: 1px solid #eee;
            border-radius: 10px;
            overflow: hidden;
            background: #fff;
            transition: 0.3s;
        }

            .laptop-card:hover {
                box-shadow: 0 5px 20px rgba(0,0,0,0.1);
            }

            /* IMAGE */
            .laptop-card .product-image {
                background: #f5f5f5;
                padding: 20px;
            }

            .laptop-card img {
                max-height: 180px;
                object-fit: contain;
            }

            /* TITLE */
            .laptop-card .title {
                font-size: 15px;
                font-weight: 600;
                min-height: 45px;
            }

            /* SPECS BOX */
            .laptop-card .specs {
                background: #f1f1f1;
                border-radius: 10px;
                padding: 10px;
                margin: 10px 0;
                display: flex;
                flex-wrap: wrap;
                gap: 8px 12px;
            }

                .laptop-card .specs i {
                    font-size: 14px;
                    color: #666;
                    margin-right: 4px;
                }

                .laptop-card .specs div {
                    display: flex;
                    align-items: center;
                    gap: 4px;
                    white-space: normal; /* cho phép xuống dòng */
                    word-break: break-word; /* tránh tràn */
                }

            /* PRICE */
            .laptop-card .new-price {
                color: red;
                font-size: 18px;
                font-weight: bold;
            }

            /* RATING */
            .laptop-card .rating {
                font-size: 14px;
                margin-top: 5px;
            }
    </style>
</head>

