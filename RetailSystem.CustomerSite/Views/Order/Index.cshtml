@model RetailSystem.Shared.ViewModels.CheckoutViewModel

<div class="container py-5">
    <div class="row g-5">
        <div class="col-md-6 col-lg-6 order-md-last">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-white py-3 border-bottom">
                    <h5 class="mb-0 text-primary fw-bold">
                        <i class="bi bi-cart3 me-2"></i>Order Detail (@Model.CartItems.Count)
                    </h5>
                </div>
                <div class="card-body p-0">
                    <!-- Danh sách sản phẩm -->
                    <div class="order-summary-list" style="max-height: 500px; overflow-y: auto;">
                        @foreach (var item in Model.CartItems)
                        {
                            var firstImage = item.Product.Images?.OrderBy(x => x.Id).FirstOrDefault()?.Url
                            ?? "/images/default-product.png";

                            <div class="p-3 border-bottom">
                                <div class="row align-items-center g-3">
                                    <!-- Hình ảnh sản phẩm -->
                                    <div class="col-3 col-md-4 col-lg-3">
                                        <div class="img-thumbnail border-0 bg-light p-1">
                                            <img src="@firstImage" alt="@item.Product.Name"
                                                 class="img-fluid rounded"
                                                 style="width: 80px; height: 80px; object-fit: cover;">
                                        </div>
                                    </div>
                                    <!-- Thông tin sản phẩm -->
                                    <div class="col-9 col-md-8 col-lg-9">
                                        <h6 class="mb-1 text-truncate" title="@item.Product.Name">
                                            @item.Product.Name
                                        </h6>
                                        <div class="d-flex justify-content-between align-items-center">
                                            <small class="text-muted">
                                                SL: <strong>@item.Quantity</strong> x @item.Product.Price.ToString("N0")₫
                                            </small>
                                            <span class="fw-bold text-dark">
                                                @((item.Quantity * item.Product.Price).ToString("N0"))₫
                                            </span>
                                        </div>
                                        @if (!string.IsNullOrEmpty(item.Product.RAM))
                                        {
                                            <div class="mt-1">
                                                <span class="badge bg-light text-dark fw-normal border" style="font-size: 0.7rem;">
                                                    @item.Product.RAM / @item.Product.SSD
                                                </span>
                                            </div>
                                        }
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                </div>

                <!-- Tổng tiền -->
                <div class="card-footer bg-light p-4 border-0">
                    <div class="d-flex justify-content-between mb-2">
                        <span class="text-muted">Estimate:</span>
                        <span>@Model.CartItems.Sum(x => x.Quantity * x.Product.Price).ToString("N0")₫</span>
                    </div>
                    <div class="d-flex justify-content-between mb-2">
                        <span class="text-muted">Delivery Fee:</span>
                        <span class="text-success">Free</span>
                    </div>
                    <hr>
                    <div class="d-flex justify-content-between align-items-center">
                        <span class="h5 mb-0 fw-bold">Total:</span>
                        <span class="h4 mb-0 text-primary fw-bold">
                            @Model.CartItems.Sum(x => x.Quantity * x.Product.Price).ToString("N0")₫
                        </span>
                    </div>
                </div>
            </div>

            <!-- Banner tin cậy (Tùy chọn) -->
            <div class="mt-3 p-3 bg-white rounded shadow-sm d-flex align-items-center border">
                <i class="bi bi-shield-check text-success fs-2 me-3"></i>
                <div>
                    <div class="fw-bold">SAFETY PAYMENT</div>
                    <small class="text-muted">Your information will always be kept completely confidential.</small>
                </div>
            </div>
        </div>

@*         User Shipping Information*@        
        <div class="col-md-6 col-lg-6">
            <h4 class="mb-3 border-bottom pb-2">Delivery information</h4>
            <form asp-action="CreateOrder" asp-controller="Order" method="post" class="needs-validation">
                <div class="row g-3">
                    <div class="col-12">
                        <label asp-for="OrderData.FullName" class="form-label">Full Name</label>
                        <input asp-for="OrderData.FullName" class="form-control" placeholder="Jhony Silverhand" required>
                        <span asp-validation-for="OrderData.FullName" class="text-danger small"></span>
                    </div>

                    <div class="col-12">
                        <label asp-for="OrderData.PhoneNumber" class="form-label">Phone</label>
                        <input asp-for="OrderData.PhoneNumber" class="form-control" placeholder="0901234567" required>
                        <span asp-validation-for="OrderData.PhoneNumber" class="text-danger small"></span>
                    </div>

                    <div class="col-12">
                        <label asp-for="OrderData.Address" class="form-label">Full Address</label>
                        <input asp-for="OrderData.Address" class="form-control" placeholder="1600 Pennsylvania Avenue N.W., Washington, D.C. 20500" required>
                        <span asp-validation-for="OrderData.Address" class="text-danger small"></span>
                    </div>

                    <div class="col-12">
                        <label asp-for="OrderData.Note" class="form-label">Note (option)</label>
                        <textarea asp-for="OrderData.Note" class="form-control" rows="3" placeholder="Ex: Office Hour, etc..."></textarea>
                    </div>
                </div>

                <hr class="my-4">

                <h4 class="mb-3">Payment Method</h4>
                <div class="my-3">
                    <div class="form-check">
                        <input id="cod" name="paymentMethod" type="radio" class="form-check-input" checked required>
                        <label class="form-check-label" for="cod">Cash On Delivery (COD)</label>
                    </div>
                    <div class="form-check">
                        <input id="vnpay" name="paymentMethod" type="radio" class="form-check-input" disabled>
                        <label class="form-check-label" for="vnpay">Online Payment (VNPay) - <span class="badge bg-secondary">Coming Soon</span></label>
                    </div>
                </div>

                <hr class="my-4">

                <button class="w-100 btn btn-primary btn-lg" type="submit">COMFIRMED ORDER</button>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}