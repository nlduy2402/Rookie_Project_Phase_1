@using RetailSystem.Shared.ViewModels
@model ProductDetailViewModel
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    .product-detail-image {
        height: 400px;
        background: #f5f5f5;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 10px;
    }

        .product-detail-image img {
            max-height: 100%;
            max-width: 100%;
            object-fit: contain;
        }

    /* THUMB */
    .thumb {
        width: 70px;
        height: 70px;
        object-fit: cover;
        cursor: pointer;
        border-radius: 6px;
        border: 2px solid transparent;
    }

        .thumb:hover {
            border-color: #0d6efd;
        }

    /* PRICE */
    .price-box {
        margin: 10px 0;
    }

    .new-price {
        font-size: 30px;
        font-weight: 700;
        color: #e60023;
    }

    .old-price {
        text-decoration: line-through;
        color: #999;
        margin-left: 10px;
    }

    /* SPECS */
    .spec-box {
        background: #f1f1f1;
        padding: 12px;
        border-radius: 8px;
    }

        .spec-box div {
            font-size: 14px;
            margin-bottom: 6px;
        }

    /* BUTTON */
    .add-cart-btn {
        height: 48px;
        font-size: 16px;
        font-weight: 600;
    }
</style>

<div class="container mt-4 mb-100">
    <div class="row g-4 align-items-stretch">

        <!-- LEFT: IMAGE -->
        <div class="col-md-6">
            <div class="product-detail-image">
                <img id="mainImage"
                     src="@Model.Images.FirstOrDefault()"
                     class="img-fluid">
            </div>

            <!-- THUMB -->
            <div class="d-flex gap-2 mt-3">
                @foreach (var img in Model.Images)
                {
                    <img src="@img"
                         class="thumb"
                         onclick="changeImage('@img')" />
                }
            </div>
        </div>

        <!-- RIGHT: INFO -->
        <div class="col-md-6 d-flex flex-column">


            <!-- NAME -->
            <h3 class="fw-bold">@Model.Name</h3>

            <!-- PRICE -->
            <div class="price-box">
                <span class="new-price">@Model.PriceFormatted</span>
                <!-- optional -->
                <!-- <span class="old-price">45.000.000đ</span> -->
            </div>

            <!-- SPECS -->
            <div class="spec-box mt-3">
                <div><i class="bi bi-cpu"></i> @Model.ChipSet</div>
                <div><i class="bi bi-memory"></i> @Model.RAM</div>
                <div><i class="bi bi-hdd"></i> @Model.SSD</div>
            </div>

            <!-- DESCRIPTION -->
            <div class="mt-4">
                <h5>Description</h5>
                <p class="text-muted">@Model.Description</p>
            </div>

            <!-- BUTTON: luôn nằm đáy -->
            <div class="mt-auto">
                    <button onclick="addToCart(@Model.Id)" class="btn btn-primary w-100 add-cart-btn">
                        Add to Cart
                    </button>
            </div>

        </div>
    </div>
</div>
<div class="mt-4">

    <h5>Rating</h5>

    <!-- ⭐ SUMMARY -->
    <div class="d-flex align-items-center gap-2 mb-2">
        <span class="fs-4 fw-bold text-warning">
            @Model.AverageRating.ToString("0.0")
        </span>

        <div>
            @for (int i = 1; i <= 5; i++)
            {
                if (i <= Math.Floor(Model.AverageRating))
                {
                    <i class="bi bi-star-fill text-warning"></i>
                }
                else
                {
                    <i class="bi bi-star text-warning"></i>
                }
            }
        </div>

        <span class="text-muted">
            (@Model.TotalReviews reviews)
        </span>
    </div>

    @if (Model.Reviews.Any())
    {
        <div class="mt-3">

            @foreach (var r in Model.Reviews)
            {
                <div class="review-item mb-3">

                    <div class="d-flex justify-content-between">
                        <strong>Annonymus</strong>
                        <small class="text-muted">
                            @r.CreatedAt.ToString("dd/MM/yyyy")

                        </small>
                    </div>

                    <div class="review-stars mb-1">
                        @for (int i = 0; i < r.Rating; i++)
                        {
                            <i class="bi bi-star-fill"></i>
                        }
                    </div>

                    <div>@r.Comment</div>

                </div>
            }

        </div>
    }

</div>
<link href="~/css/Rate.css" rel="stylesheet" />
<script>
    function changeImage(src) {
        document.getElementById("mainImage").src = src;
    }
</script>