@using RetailSystem.Shared.ViewModels
@model ProductDetailViewModel
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    :root {
        --ink: #141414;
        --ink-soft: #5a5a5a;
        --ink-muted: #9a9a9a;
        --surface: #f9f8f6;
        --surface-2: #f2f1ee;  
        --border: #e4e3df;
        --accent: #e53e3e;
        --accent-dk: #c53030;
        --blue: #2563eb;
        --radius: 14px;
        --radius-sm: 8px;
    }
    .product-detail-image {
        height: 400px;
        background: #f5f5f5;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 10px;
    }

        .product-detail-image img {
            max-height: 100%;
            max-width: 100%;
            object-fit: contain;
        }

    /* THUMB */
    .thumb {
        width: 70px;
        height: 70px;
        object-fit: cover;
        cursor: pointer;
        border-radius: 6px;
        border: 2px solid transparent;
    }

        .thumb:hover {
            border-color: #0d6efd;
        }

    /* PRICE */
    .price-box {
        margin: 10px 0;
    }

    .new-price {
        font-size: 30px;
        font-weight: 700;
        color: #e60023;
    }

    .old-price {
        text-decoration: line-through;
        color: #999;
        margin-left: 10px;
    }

    /* SPECS */
    .spec-box {
        background: #f1f1f1;
        padding: 12px;
        border-radius: 8px;
    }

        .spec-box div {
            font-size: 14px;
            margin-bottom: 6px;
        }

    /* BUTTON */
    .add-cart-btn {
        height: 48px;
        font-size: 16px;
        font-weight: 600;
    }
    
    /*Review*/
    .pd-reviews {
        margin-top: 52px;
    }

    .pd-section-title {
        font-size: 22px;
        margin-bottom: 20px;
        padding-bottom: 12px;
        border-bottom: 1.5px solid var(--border);
        color: var(--ink);
    }

    .pd-rating-summary {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: var(--radius);
        padding: 20px 24px;
        display: inline-flex;
        align-items: center;
        gap: 16px;
        margin-bottom: 24px;
    }

    .pd-avg-score {
        font-size: 42px;
        font-weight: 700;
        line-height: 1;
        font-family: 'DM Serif Display', serif;
        color: var(--ink);
    }

    .pd-stars-row i {
        font-size: 16px;
        color: #f59e0b;
    }

    .pd-review-count {
        font-size: 13px;
        color: var(--ink-muted);
        margin-top: 3px;
    }

    .pd-review-card {
        border: 1px solid var(--border);
        border-radius: var(--radius);
        padding: 16px 18px;
        margin-bottom: 12px;
        background: #fff;
        transition: border-color .18s;
    }

        .pd-review-card:hover {
            border-color: #ccc;
        }

    .pd-review-top {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 8px;
        flex-wrap: wrap;
        gap: 6px;
    }

    .pd-reviewer {
        font-size: 14px;
        font-weight: 600;
        color: var(--ink);
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .pd-avatar {
        width: 30px;
        height: 30px;
        border-radius: 50%;
        background: var(--surface-2);
        border: 1px solid var(--border);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 13px;
        color: var(--ink-muted);
        flex-shrink: 0;
    }

    .pd-review-date {
        font-size: 12px;
        color: var(--ink-muted);
    }

    .pd-review-stars i {
        font-size: 13px;
        color: #f59e0b;
    }

    .pd-review-comment {
        font-size: 14px;
        color: var(--ink-soft);
        line-height: 1.6;
        margin-top: 6px;
    }

    .spec-table {
        background: #f8f9fa;
        border-radius: 6px;
        overflow: hidden;
        font-size: 14px;
    }

    .spec-group-title {
        background: #e9ecef;
        padding: 10px;
        font-weight: 600;
    }

    .spec-row {
        display: flex;
        justify-content: space-between;
        padding: 10px;
        border-bottom: 1px solid #eee;
    }

        .spec-row span:first-child {
            color: #555;
        }

    .product-long-desc {
        line-height: 1.6;
    }

    .product-desc-img {
        width: 70%;
        max-height: 350px;
        object-fit: cover;
        border-radius: 10px;
        transition: 0.3s;
    }

        .product-desc-img:hover {
            transform: scale(1.02);
        }
</style>

<div class="container mt-4 mb-100">
    <div class="row g-4 align-items-stretch">

        <!-- LEFT: IMAGE -->
        <div class="col-md-6">
            <div class="product-detail-image">
                <img id="mainImage"
                     src="@Model.Images.FirstOrDefault()"
                     class="img-fluid">
            </div>

            <!-- THUMB -->
            <div class="d-flex gap-2 mt-3">
                @foreach (var img in Model.Images)
                {
                    <img src="@img"
                         class="thumb"
                         onclick="changeImage('@img')" />
                }
            </div>
        </div>

        <!-- RIGHT: INFO -->
        <div class="col-md-6 d-flex flex-column">


            <!-- NAME -->
            <h3 class="fw-bold">@Model.Name</h3>

            <!-- PRICE -->
            <div class="price-box">
                <span class="new-price">@Model.PriceFormatted</span>
                <!-- optional -->
                <!-- <span class="old-price">45.000.000đ</span> -->
            </div>

            <!-- SPECS -->
            <div class="spec-box mt-3">
                <div><i class="bi bi-cpu"></i> @Model.ChipSet</div>
                <div><i class="bi bi-memory"></i> @Model.RAM</div>
                <div><i class="bi bi-hdd"></i> @Model.SSD</div>
            </div>

            <!-- DESCRIPTION -->
            <div class="mt-4">
                <h5>Description</h5>
                <p class="text-muted">@Model.Description</p>
            </div>

            <!-- BUTTON: luôn nằm đáy -->
            <div class="mt-auto">
                    <button onclick="addToCart(@Model.Id)" class="btn btn-primary w-100 add-cart-btn">
                        Add to Cart
                    </button>
            </div>

        </div>
    </div>
</div>

<div class="container mt-5">
    <div class="row g-4">

        <!-- LEFT: DESCRIPTION -->
        <div class="col-md-7">
            <h5 class="fw-bold mb-3">Product Description</h5>

            <h6 class="fw-bold">
                @Model.Name
            </h6>

            <!-- đoạn mô tả ngắn -->
            <p class="text-muted">
                @Model.Description
            </p>

            <!-- mô tả dài (có thể render HTML raw sau) -->
            <div class="product-long-desc">
                A portable, compact personal computer (PC) designed for mobile use, typically featuring a "clamshell" design with a screen on the upper lid and a keyboard/touchpad on the lower base
            </div>

            <!-- image minh họa -->
            <div class="mt-3">
                <img src="@Model.Images.FirstOrDefault()"
                     class="product-desc-img">
            </div>

            <div class="text-muted">
                The HyperX OMEN 15 delivers fast performance that pushes your gaming farther than ever. With NVIDIA® GeForce RTX™ 50 Series GPUs and Intel® Core™ CPUs [2], Unleashed Mode for manual overclocking, and with a single click on OMEN AI, you can maximize your FPS without the hassle.
            </div>
        </div>

        <!-- RIGHT: TECH SPECS -->
        <div class="col-md-5">
            <h5 class="fw-bold mb-3">SPECIFICATIONS</h5>

            <div class="spec-table">

                <div class="spec-group-title">External I/O Port</div>

                <div class="spec-row">
                    <span>Port</span>
                    <span>HDMI, DP, x2 USB-C , Type C</span>
                </div>

                <div class="spec-row">
                    <span>WiFi</span>
                    <span>Wifi 7</span>
                </div>

                <div class="spec-row">
                    <span>Bluetooth</span>
                    <span>Bluetooth 5.6</span>
                </div>

                <div class="spec-row">
                    <span>Webcam</span>
                    <span>Ultra HD</span>
                </div>

                <div class="spec-group-title mt-3">Display</div>

                <div class="spec-row">
                    <span>Tec</span>
                    <span>OLED+</span>
                </div>

                <div class="spec-row">
                    <span>Resolution</span>
                    <span>1920x1080</span>
                </div>

                <div class="spec-row">
                    <span>Refresh Rate</span>
                    <span>144Hz</span>
                </div>

                <div class="spec-group-title mt-3">Audio</div>
                <div class="spec-row">
                    <span>Audio Features</span>
                    <span>
                        DTS:X® Ultra
                        Dual speakers
                        HP Audio Boost
                        HyperX
                    </span>
                </div>

                <div class="spec-group-title mt-3">Other</div>
                <div class="spec-row">
                    <span>Battery</span>
                    <span>
                        4 Cell, 82Whr. Supports battery fast charge
                    </span>
                </div>
                <div class="spec-row">
                    <span>Dimensions</span>
                    <span>13.5 x 9.96 x 0.89 </span>
                </div>
            </div>
        </div>
    </div>
</div>

<h2 class="pd-section-title">You May Also Like</h2>
@await Component.InvokeAsync("TopSellingProducts",4)

<div class="pd-reviews">
    <h2 class="pd-section-title">Rating</h2>

    <!-- Summary -->
    <div class="pd-rating-summary">
        <div class="pd-avg-score">@Model.AverageRating.ToString("0.0")</div>
        <div>
            <div class="pd-stars-row">
                @for (int i = 1; i <= 5; i++)
                {
                    if (i <= Math.Floor(Model.AverageRating))
                    {
                        <i class="bi bi-star-fill"></i>
                    }
                    else
                    {
                        <i class="bi bi-star"></i>
                    }
                }
            </div>
            <div class="pd-review-count">@Model.TotalReviews reviews </div>
        </div>
    </div>
    
    <!-- Review list -->
    @if (Model.Reviews.Any())
    {
        <div>
            @foreach (var r in Model.Reviews)
            {
                <div class="pd-review-card">
                    <div class="pd-review-top">
                        <div class="pd-reviewer">
                            <div class="pd-avatar">
                                <i class="bi bi-person" aria-hidden="true"></i>
                            </div>
                            Anonymous
                        </div>
                        <span class="pd-review-date">@r.CreatedAt.ToString("dd/MM/yyyy")</span>
                    </div>

                    <div class="pd-review-stars">
                        @for (int i = 0; i < r.Rating; i++)
                        {
                            <i class="bi bi-star-fill" aria-hidden="true"></i>
                        }
                    </div>

                    <p class="pd-review-comment">@r.Comment</p>
                </div>
            }
        </div>
    }
</div>
<link href="~/css/Rate.css" rel="stylesheet" />
<script>
    function changeImage(src) {
        document.getElementById("mainImage").src = src;
    }
</script>